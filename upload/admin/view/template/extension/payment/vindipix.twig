{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-payment" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i class="fa fa-reply"></i></a></div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
	{% if atual %}
	<div class="alert alert-info"><i class="fa fa-exclamation-circle"></i> Existe uma nova versão do módulo <b>{{ module_name }}</b> faça o download <a href="{{ murl }}" target="_blank">AQUI</a> <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
	{% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_edit }}</h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-payment" class="form-horizontal">
	 <ul class="nav nav-tabs" id="tabs">
            <li class="active"><a href="#tab-general" data-toggle="tab">{{ tab_general }}</a></li>
            <li><a href="#tab-help" data-toggle="tab">{{ tab_help }}</a></li>
          </ul>
	 <div class="tab-content">

    <div class="tab-pane active" id="tab-general">
         <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_vindipix_title" value="{{ payment_vindipix_title }}" placeholder="{{ entry_title }}" id="input-title" class="form-control" />
			  {% if error_title %}
              <div class="text-danger">{{ error_title }}</div>
              {% endif %}
            </div>
          </div>
         <div class="form-group required">
            <label class="col-sm-2 control-label" for="input-token">{{ entry_token }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_vindipix_token" value="{{ payment_vindipix_token }}" placeholder="{{ entry_token }}" id="input-token" class="form-control" />
			  {% if error_token %}
              <div class="text-danger">{{ error_token }}</div>
              {% endif %}
            </div>
          </div>
         <div class="form-group" style="display:none;">
            <label class="col-sm-2 control-label" for="input-days">{{ entry_days }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_vindipix_days" value="{{ payment_vindipix_days }}" placeholder="{{ entry_days }}" id="input-days" class="form-control" />
            </div>
          </div>
		 <div class="form-group required">
		 <label class="col-sm-2 control-label">{{ entry_doc }}</label>
			 <div class="col-sm-10">
			        <select name="payment_vindipix_doc" id="input-doc" class="form-control">
				    <option value="">{{ text_none }}</option>
				    {% for custom_field in custom_fields  %}
				    {% if custom_field.location == 'account' %}
					{% if payment_vindipix_doc == custom_field.custom_field_id %}
					<option value="{{ custom_field.custom_field_id }}" selected>{{ custom_field.name }}</option>
					{% else %}
					<option value="{{ custom_field.custom_field_id }}">{{ custom_field.name }}</option>
					{% endif %}
					{% endif %}
					{% endfor %}
			        </select>
			  {% if error_doc %}
              <div class="text-danger">{{ error_doc }}</div>
              {% endif %}	 
			</div>
		  </div>
         <div class="form-group">
		 <label class="col-sm-2 control-label">{{ entry_doc2 }}</label>
			 <div class="col-sm-10">
			        <select name="payment_vindipix_doc2" id="input-doc" class="form-control">
				    <option value="">{{ text_none }}</option>
				    {% for custom_field in custom_fields  %}
				    {% if custom_field.location == 'account' %}
					{% if payment_vindipix_doc2 == custom_field.custom_field_id %}
					<option value="{{ custom_field.custom_field_id }}" selected>{{ custom_field.name }}</option>
					{% else %}
					<option value="{{ custom_field.custom_field_id }}">{{ custom_field.name }}</option>
					{% endif %}
					{% endif %}
					{% endfor %}
			        </select>	 
			</div>
		  </div>
         <div class="form-group">
		 <label class="col-sm-2 control-label">{{ entry_raz }}</label>
			 <div class="col-sm-10">
			        <select name="payment_vindipix_raz" id="input-doc" class="form-control">
				    <option value="">{{ text_none }}</option>
				    {% for custom_field in custom_fields  %}
				    {% if custom_field.location == 'account' %}
					{% if payment_vindipix_raz == custom_field.custom_field_id %}
					<option value="{{ custom_field.custom_field_id }}" selected>{{ custom_field.name }}</option>
					{% else %}
					<option value="{{ custom_field.custom_field_id }}">{{ custom_field.name }}</option>
					{% endif %}
					{% endif %}
					{% endfor %}
			        </select>	 
			</div>
		  </div>
		 <div class="form-group required">
		 <label class="col-sm-2 control-label">{{ entry_number }}</label>
			 <div class="col-sm-10">
			        <select name="payment_vindipix_number" id="input-number" class="form-control">
				    <option value="">{{ text_none }}</option>
				    {% for custom_field in custom_fields  %}
				    {% if custom_field.location == 'address' %}
					{% if payment_vindipix_number == custom_field.custom_field_id %}
					<option value="{{ custom_field.custom_field_id }}" selected>{{ custom_field.name }}</option>
					{% else %}
					<option value="{{ custom_field.custom_field_id }}">{{ custom_field.name }}</option>
					{% endif %}
					{% endif %}
					{% endfor %}
			        </select>
			  {% if error_number %}
              <div class="text-danger">{{ error_number }}</div>
              {% endif %}	 
			</div>
		  </div>
		 <div class="form-group">
		 <label class="col-sm-2 control-label">{{ entry_complement }}</label>
			 <div class="col-sm-10">
			        <select name="payment_vindipix_complement" id="input-complement" class="form-control">
					<option value="">{{ text_none }}</option>
				    {% for custom_field in custom_fields  %}
				    {% if custom_field.location == 'address' %}
					{% if payment_vindipix_complement == custom_field.custom_field_id %}
					<option value="{{ custom_field.custom_field_id }}" selected>{{ custom_field.name }}</option>
					{% else %}
					<option value="{{ custom_field.custom_field_id }}">{{ custom_field.name }}</option>
					{% endif %}
					{% endif %}
					{% endfor %}
			        </select>
			</div>
		  </div>
		 <div class="form-group">
            <label class="col-sm-2 control-label" for="input-total"><span data-toggle="tooltip" title="{{ help_total }}">{{entry_total }}</span></label>
            <div class="col-sm-10">
              <input type="text" name="payment_vindipix_total" value="{{ payment_vindipix_total }}" placeholder="{{ entry_total }}" id="input-total" class="form-control" />
            </div>
          </div>
   		 <div class="form-group">
            <label class="col-sm-2 control-label" for="input-order-status">{{ entry_order_status_pen }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_order_status_id" id="input-order-status" class="form-control">
                {% for order_status in order_statuses %}
                {% if order_status.order_status_id == payment_vindipix_order_status_id %}
                <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                {% else %}
                <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
		 <div class="form-group">
            <label class="col-sm-2 control-label" for="input-order-status">{{ entry_order_status_can }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_order_status_id1" id="input-order-status" class="form-control">
                {% for order_status in order_statuses %}
                {% if order_status.order_status_id == payment_vindipix_order_status_id1 %}
                <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                {% else %}
                <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
		  <div class="form-group">
            <label class="col-sm-2 control-label" for="input-order-status">{{ entry_order_status_apr }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_order_status_id2" id="input-order-status" class="form-control">
                {% for order_status in order_statuses %}
                {% if order_status.order_status_id == payment_vindipix_order_status_id2 %}
                <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                {% else %}
                <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
		 <div class="form-group">
            <label class="col-sm-2 control-label" for="input-order-status">{{ entry_order_status_con }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_order_status_id3" id="input-order-status" class="form-control">
                {% for order_status in order_statuses %}
                {% if order_status.order_status_id == payment_vindipix_order_status_id3 %}
                <option value="{{ order_status.order_status_id }}" selected="selected">{{ order_status.name }}</option>
                {% else %}
                <option value="{{ order_status.order_status_id }}">{{ order_status.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
         <div class="form-group">
            <label class="col-sm-2 control-label" for="input-geo-zone">{{ entry_geo_zone }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_geo_zone_id" id="input-geo-zone" class="form-control">
                <option value="0">{{ text_all_zones }}</option>
                {% for geo_zone in geo_zones %}
                {% if geo_zone.geo_zone_id == payment_vindipix_geo_zone_id %}
                <option value="{{ geo_zone.geo_zone_id }}" selected="selected">{{ geo_zone.name }}</option>
                {% else %}
                <option value="{{ geo_zone.geo_zone_id }}">{{ geo_zone.name }}</option>
                {% endif %}
                {% endfor %}
              </select>
            </div>
          </div>
          <div class="form-group">
            <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
            <div class="col-sm-10">
              <input type="text" name="payment_vindipix_sort_order" value="{{ payment_vindipix_sort_order }}" placeholder="{{ entry_sort_order }}" id="input-sort-order" class="form-control" />
            </div>
          </div>
           <div class="form-group">
            <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
            <div class="col-sm-10">
              <select name="payment_vindipix_status" id="input-status" class="form-control">
                {% if payment_vindipix_status %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                <option value="0">{{ text_disabled }}</option>
                {% else %}
                <option value="1">{{ text_enabled }}</option>
                <option value="0" selected="selected">{{ text_disabled }}</option>
                {% endif %}
              </select>
			  <br>
			  <p>{{text_terms }} <a href="https://opencartmaster.com.br/{{ text_l }}" target="_blank">{{ text_t }}</a></p>
            </div>
          </div>
          
		</div>
           
    <div class="tab-pane" id="tab-help">
	   <fieldset>
       <legend>{{ text_h }}</legend>
       <h4><i class="fa fa-code"></i> {{ module_name }} - {{ version }} </h4>
       <h4><i class="fa fa-envelope"></i> <a href="mailto:suporte@opencartmaster.com.br">suporte@opencartmaster.com.br</a></h4>
       <h4><i class="fa fa-whatsapp"></i> <a href="https://wa.me/551142542450" target="_blank">11 4254-2450</a></h4>
        <h4><i class="fa fa-globe"></i><a href="https://opencartmaster.com.br" target="_blank">opencartmaster.com.br</a></h4>
	     <p>{{ text_support }}</p>
       </fieldset>
	   </div>
		 
		</div>
      </form>
      </div>
    </div>
  </div>
</div>
{{ footer }} 